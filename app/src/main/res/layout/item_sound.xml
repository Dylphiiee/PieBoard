<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/glass_card_bg"
    android:padding="12dp"
    android:layout_marginBottom="10dp"
    android:elevation="2dp">

    <ImageButton
        android:id="@+id/btnPlay"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/circle_play_bg"
        android:src="@drawable/ic_play"
        android:padding="12dp"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="end"
        tools:text="Bruh Sound Effect"
        xmlns:tools="http://schemas.android.com/tools" />

    <ImageButton
        android:id="@+id/btnFavorite"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/circle_glass_bg"
        android:src="@drawable/ic_star_outline"
        android:padding="8dp"
        android:contentDescription="@string/favorite_toggle" />

    <ImageButton
        android:id="@+id/btnEdit"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/circle_glass_bg"
        android:src="@drawable/ic_edit"
        android:padding="8dp"
        android:contentDescription="@null" />

    <ImageButton
        android:id="@+id/btnDelete"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/circle_glass_bg"
        android:src="@drawable/ic_delete"
        android:padding="8dp"
        android:contentDescription="@null" />

</LinearLayout>
