<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="145dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_card_bg_strong"
    android:padding="6dp">

    <!-- Compact header: app mark + loop / stop controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_pie_logo_mark"
            android:contentDescription="@null" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnLoopToggle"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/circle_glass_bg"
            android:src="@drawable/ic_loop"
            android:padding="5dp"
            android:contentDescription="@string/loop_toggle" />

        <ImageButton
            android:id="@+id/btnStop"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/circle_glass_bg"
            android:src="@drawable/ic_stop"
            android:padding="5dp"
            android:contentDescription="@string/stop_sound" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/glass_stroke_soft"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvTabAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:text="@string/tab_all"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingVertical="5dp"
            android:background="@drawable/tab_pill_active_bg"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tvTabFavorites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tab_favorites"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingVertical="5dp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- Fixed height so the panel itself never grows or shrinks, regardless of tab/content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="180dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPanelSounds"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:fadeScrollbars="true"
            android:overScrollMode="never"
            tools:listitem="@layout/item_floating_sound" />

        <TextView
            android:id="@+id/tvPanelEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/empty_state"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
