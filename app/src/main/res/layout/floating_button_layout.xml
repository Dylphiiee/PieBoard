<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <ImageView
        android:id="@+id/ivFloatingButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/floating_button_bg"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/ivFloatingIcon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:padding="14dp"
        android:src="@drawable/ic_pie_logo_mark"
        android:contentDescription="@null" />

    <View
        android:id="@+id/badgeDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/circle_badge_bg" />

</FrameLayout>
